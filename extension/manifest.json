{
  "manifest_version": 3,
  "name": "UtubeHolic",
  "version": "2.2.5",
  "description": "Grab like a cat from Youtube, Twitter(X), Instagram",
  "permissions": [
    "contextMenus",
    "tabs",
    "cookies",
    "storage",
    "history",
    "alarms"
  ],
  "web_accessible_resources": [{
    "resources": ["images/*.png"],
    "matches": ["<all_urls>"]
  }],
  "host_permissions": [
    "*://127.0.0.1/*",
    "*://localhost/*",
    "*://*.youtube.com/*",
    "*://youtube.com/*",
    "*://*.google.com/*",
    "*://accounts.google.com/*",
    "*://*.twitter.com/*",
    "*://twitter.com/*",
    "*://*.x.com/*",
    "*://x.com/*",
    "*://*.instagram.com/*",
    "*://instagram.com/*"
  ],
  "action": {
    "default_title": "Add to current page download queue"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtube.com/*"
      ],
      "js": [
        "content/toast.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtube.com/*"
      ],
      "js": [
        "content/ns.js",
        "content/messaging.js",
        "content/settings.js",
        "content/youtube.js",
        "content/badge.js",
        "content/engine.js",
        "content/history.js",
        "content/hooks.js",
        "content/main.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.twitter.com/*",
        "*://twitter.com/*",
        "*://*.x.com/*",
        "*://x.com/*"
      ],
      "js": [
        "content/toast.js",
        "content/twitter.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.instagram.com/*",
        "*://instagram.com/*"
      ],
      "js": [
        "content/toast.js",
        "content/instagram.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  },
  "short_name": "UtubeHolic"
}