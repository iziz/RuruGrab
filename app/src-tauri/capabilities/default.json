{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "dialog:allow-message",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "../binaries/yt-dlp",
          "sidecar": true,
          "args": true
        },
        {
          "name": "../binaries/ffmpeg",
          "sidecar": true,
          "args": true
        },
        {
          "name": "../binaries/ffprobe",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}